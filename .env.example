# HelixPay — environment template. Copy to .env (chmod 600) and fill in real
# values. .env is gitignored and MUST NEVER be committed. On the VM it lives on
# the box only. Secrets are read exclusively from the environment (helixpay.config).

# --- Postgres (the compose 'db' service) -------------------------------------
# Pick a strong password. It MUST match the password embedded in DATABASE_URL below.
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- App secrets (LLM + embeddings) ------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
VOYAGE_API_KEY=your-voyage-api-key

# --- Database connection -----------------------------------------------------
# The password here MUST equal POSTGRES_PASSWORD above.
#   * In Docker (make up):  host 'db'      -> postgresql://postgres:<pw>@db:5432/helixpay
#   * Bare-metal local dev:  host 127.0.0.1 -> postgresql://postgres:<pw>@127.0.0.1:5432/helixpay
DATABASE_URL=postgresql://postgres:change-me-to-a-strong-password@db:5432/helixpay
