.env
# SP_015 smoke-loop env (carries the helixpay_smoke Postgres password). The bare `.env`
# line above does NOT match these — list them explicitly (and never use `.env.*`, which
# would swallow the committed `.env.example`).
.env.smoke
eval/smoke/.env
# SP_015 generated smoke corpus + filtered oracle — regenerate with `python -m eval.smoke.build_smoke`.
eval/smoke/data/
eval/smoke/facts.yaml
# SP_015 generated proving artifacts (per-doc ledger + machine result) — regenerate via scripts/run_smoke.py.
eval/smoke/ledger.json
eval/smoke/SP015_smoke_result.json
*.key
*.pem
credentials*
# SP_016 production seed dump (full corpus DB) — never tracked; prod_seed.sh traps it for removal.
*.pgdump
.prod_seed_dump.pgdump
__pycache__/
.pytest_cache/
*.pyc
.pre_impl_passed

# Python environments / build + tooling caches
.venv/
*.egg-info/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml

# DEV_RULES source bundle: operative copies (validators/, practices/, scripts/,
# templates) are checked out at project root by the bootstrap. The bundle keeps
# its own nested .git, so ignore it here to avoid an embedded repo.
DEV_RULES/
.docs_reconciled

# Agent-private git worktrees (DEV_REINFORCE F-6) and IDE settings — never tracked.
.claude/worktrees/
.idea/

# Paid LLM adjudication cache — regeneratable, off the offline run/replay path.
.adjudication-cache/
# Postgres snapshots are regeneratable; keep ONLY the one make run restores.
*.dump
!workspace/snapshots/helixpay_full-67-20260612.dump
